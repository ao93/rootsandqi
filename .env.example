# Choose LLM provider: "ollama" (free, local) or "anthropic" (paid, cloud)
LLM_PROVIDER=ollama

# --- Ollama settings (used if LLM_PROVIDER=ollama) ---
# Requires Ollama installed and running locally: https://ollama.com
# Pull models first:
#   ollama pull llama3
#   ollama pull nomic-embed-text
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# --- Anthropic settings (used if LLM_PROVIDER=anthropic) ---
# Get a key from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# --- Embedding model (used for herb knowledge base retrieval) ---
EMBEDDING_MODEL=nomic-embed-text

# --- Qdrant settings ---
# Run Qdrant locally via Docker:
#   docker run -p 6333:6333 -p 6334:6334 qdrant/qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=herbs

# --- MLflow settings ---
# Option A (default) - file-based local tracking, no server needed.
#   View runs with: mlflow ui --backend-store-uri ./mlruns
MLFLOW_TRACKING_URI=./mlruns
#
# Option B - MLflow tracking server via Docker (production-like, shared UI):
#   docker run -p 5000:5000 ghcr.io/mlflow/mlflow:latest \
#     mlflow server --host 0.0.0.0 --port 5000 \
#     --backend-store-uri sqlite:///mlflow.db --default-artifact-root /mlruns
#   then set: MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=rootsandqi-diagnosis

# Bump this whenever SYNDROME_MAPPING_SYSTEM_PROMPT is meaningfully changed,
# so MLflow runs can be compared across prompt versions.
SYNDROME_PROMPT_VERSION=v1
